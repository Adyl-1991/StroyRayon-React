# Frontend deployments do not need root-level backend sources or audit artifacts.
# Leading slashes are required: an unanchored "api" also removes src/api,
# which contains the frontend API client modules.
/api
/docs
/reports
/scripts/*
!/scripts/generate-bundled-order-catalog.mjs
!/scripts/sync-catalog.mjs

# Local and generated-only files.
/dist
*.log
*.zip
